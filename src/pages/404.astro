---
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../scripts/url";
---

<BaseLayout
    title="404 — Page Not Found | Sentinel Systems"
    description="The page you requested does not exist. Return to the analyzer or visit docs and API references."
>
    <main class="flex flex-1 items-center justify-center px-6 py-14 md:px-20 lg:px-40">
        <section
            class="relative w-full max-w-270 overflow-hidden rounded-md border border-neutral-200 bg-neutral-50"
        >
            <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_16%_10%,rgba(15,15,15,0.06),transparent_32%),radial-gradient(circle_at_90%_78%,rgba(15,15,15,0.05),transparent_42%)]"
            ></div>

            <div class="relative z-10 grid gap-0 md:grid-cols-[1.2fr_1fr]">
                <div class="border-b border-neutral-200 p-6 md:border-b-0 md:border-r md:p-9">
                    <div class="mb-4 inline-flex items-center gap-2 rounded-md border border-neutral-200 bg-neutral-100 px-2.5 py-1 text-[11px] uppercase tracking-wider text-neutral-500">
                        <span class="inline-block size-1.5 rounded-full bg-red-500"></span>
                        Route Error
                    </div>

                    <h1 class="mb-3 text-[29px] font-semibold leading-tight text-neutral-900 md:text-[34px]">
                        404
                        <span class="block text-[16px] font-normal text-neutral-500 md:text-[17px]">
                            We scanned this address and found nothing.
                        </span>
                    </h1>

                    <p class="max-w-xl text-[13px] leading-relaxed text-neutral-500">
                        The resource may have moved, expired, or never existed under this path. Use one of the known endpoints below to continue.
                    </p>

                    <div class="mt-6 flex flex-wrap gap-2.5">
                        <a
                            href={url("/")}
                            class="rounded-md bg-neutral-900 px-3.5 py-2 text-[13px] font-medium text-white no-underline transition-opacity hover:opacity-85"
                        >
                            Return Home
                        </a>
                        <a
                            href={url("/docs/")}
                            class="rounded-md border border-neutral-200 bg-white px-3.5 py-2 text-[13px] text-neutral-700 no-underline transition-colors hover:bg-neutral-100"
                        >
                            Open Docs
                        </a>
                        <a
                            href={url("/api/")}
                            class="rounded-md border border-neutral-200 bg-white px-3.5 py-2 text-[13px] text-neutral-700 no-underline transition-colors hover:bg-neutral-100"
                        >
                            API Reference
                        </a>
                    </div>
                </div>

                <aside class="grid content-start gap-3 p-6 md:p-9">
                    <div class="rounded-md border border-neutral-200 bg-white p-3">
                        <div class="mb-1 text-[11px] uppercase tracking-widest text-neutral-400">Status</div>
                        <div class="text-[13px] text-neutral-900">Not Found</div>
                    </div>

                    <div class="rounded-md border border-neutral-200 bg-white p-3">
                        <div class="mb-1 text-[11px] uppercase tracking-widest text-neutral-400">Protocol</div>
                        <div class="text-[13px] text-neutral-900">HTTP/1.1 404</div>
                    </div>

                    <div class="rounded-md border border-neutral-200 bg-white p-3">
                        <div class="mb-1 text-[11px] uppercase tracking-widest text-neutral-400">Hint</div>
                        <p class="text-[13px] leading-relaxed text-neutral-500">
                            Check the URL for typos or navigate with the header links.
                        </p>
                    </div>
                </aside>
            </div>
        </section>
    </main>
</BaseLayout>
