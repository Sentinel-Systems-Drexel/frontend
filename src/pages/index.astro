---
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../scripts/url";
---

<BaseLayout
    title="Email Analyzer — Sentinel Systems"
    description="The ultimate email forensics tool. Extract headers, map sender IPs, and scan for viruses. Get real-time insights and geographic data for any .eml file."
>
    <main class="flex items-start justify-center px-6 md:px-20 lg:px-40 py-12">
        <div class="flex w-full max-w-270 flex-col gap-5">
            <!-- Page header -->
            <div class="mb-1">
                <h1 class="mb-1.5 text-[22px] font-semibold text-neutral-900">
                    Email Analyzer
                </h1>
                <p class="text-[13px] leading-relaxed text-neutral-500">
                    Upload a <code
                        class="rounded bg-neutral-200 px-1 py-px text-[12px]"
                        >.eml</code
                    > file for analysis.
                </p>
            </div>

            <div class="grid">
                <label for="endpointUrl">Endpoint URL</label>
                <input
                    id="endpointUrl"
                    class="w-full bg-neutral-100 px-3 py-2 rounded-md border border-neutral-200"
                    type="text"
                    placeholder="https://api.sentinel-systems.cc"
                />
                <span class="text-neutral-400 text-xs"
                    >For development purposes only.</span
                >
            </div>
            <!-- API status -->
            <div
                id="api-status"
                class="flex items-center gap-2 rounded-md border border-neutral-200 bg-neutral-100 px-3 py-2 text-[12px] text-neutral-500"
                data-state="checking"
            >
                <span
                    id="status-dot"
                    class="size-1.75 shrink-0 rounded-full bg-neutral-400 transition-colors"
                ></span>
                <span id="status-text">Checking API…</span>
            </div>

            <!-- Drop zone -->
            <div
                id="dropzone"
                role="button"
                tabindex="0"
                aria-label="Upload EML file"
                class="cursor-pointer rounded-md border border-dashed border-neutral-300 bg-neutral-50 px-6 py-9 text-center transition-colors hover:border-neutral-900 hover:bg-black/3"
            >
                <input
                    type="file"
                    id="file-input"
                    accept=".eml"
                    class="hidden"
                />
                <div class="mb-2.5 inline-flex text-neutral-400">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M10 2L10 13M10 2L6.5 5.5M10 2L13.5 5.5"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                        <path
                            d="M3 14V16C3 17.1046 3.89543 18 5 18H15C16.1046 18 17 17.1046 17 16V14"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"></path>
                    </svg>
                </div>
                <p class="mb-1 text-[13px] text-neutral-500">
                    Drop file here or <span
                        class="cursor-pointer text-neutral-900 underline underline-offset-2"
                        >browse</span
                    >.
                </p>
                <p class="text-[11px] text-neutral-400">
                    <span id="upload-hint">Supports .eml files up to the current API limit</span>
                </p>
            </div>

            <!-- Selected file chip -->
            <div
                id="file-chip"
                hidden
                class="items-center gap-2 rounded-md border border-neutral-200 bg-neutral-100 px-3 py-2 text-[13px] text-neutral-900"
            >
                <svg
                    class="shrink-0 text-neutral-400"
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                >
                    <rect
                        x="2"
                        y="1"
                        width="8"
                        height="12"
                        rx="1"
                        stroke="currentColor"
                        stroke-width="1.2"></rect>
                    <path
                        d="M4 4.5H8M4 7H8M4 9.5H6.5"
                        stroke="currentColor"
                        stroke-width="1.2"
                        stroke-linecap="round"></path>
                </svg>
                <span id="file-chip-name"></span>
                <span
                    id="file-chip-size"
                    class="ml-0.5 text-[11px] text-neutral-400"></span>
            </div>

            <!-- Parse button + Comparison button -->
            <div class="flex gap-3">
                <button
                    id="parse-btn"
                    disabled
                    class="flex-1 cursor-pointer rounded-md border-0 bg-neutral-900 px-4 py-2.5 text-[14px] font-medium tracking-wide text-white transition-opacity active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-30 enabled:hover:opacity-85"
                >
                    Analyze Email
                </button>
                <button
                    id="compare-btn"
                    hidden
                    class="flex-1 cursor-pointer rounded-md border border-neutral-300 bg-neutral-200 px-4 py-2.5 text-[14px] font-medium tracking-wide text-neutral-900 transition-opacity active:scale-[0.99] hover:bg-neutral-300 disabled:cursor-not-allowed disabled:opacity-30"
                >
                    Compare with Legitimate Email
                </button>
            </div>

            <!-- Error -->
            <div
                id="inline-error"
                hidden
                class="rounded-md border border-red-200 bg-red-50 px-3 py-2.5 text-[13px] text-red-700"
            >
            </div>

            <!-- Loading -->
            <div
                id="loading-row"
                class="items-center gap-2.5 py-1 text-[13px] text-neutral-500"
            >
                <span
                    id="loading-spinner"
                    hidden
                    class="loader size-3.5 shrink-0 rounded-full border border-neutral-200 border-t-neutral-900"
                ></span>
                <span id="loading-text">Ready to receive files.</span>
            </div>

            <!-- Results -->
            <div id="results" hidden class="flex-col gap-6">
                <div class="h-px bg-neutral-200"></div>

                <!-- Rspamd score -->
                <section id="rspamd-section" class="flex flex-col gap-2.5" hidden>
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-400"
                    >
                        Scoring
                    </h2>
                    <div class="overflow-hidden rounded-md border border-neutral-200 bg-neutral-50">
                        <div class="flex flex-col items-center gap-1 border-b border-neutral-200 px-4 py-4">
                            <!-- Horizontal speedometer -->
                            <svg id="rspamd-gauge" viewBox="0 0 200 78" class="w-64 mx-auto" aria-hidden="true">
                                <!-- Score number -->
                                <text id="gauge-score-text" x="100" y="28" text-anchor="middle" font-size="18" font-weight="bold" fill="#111827" font-family="ui-monospace,monospace">—</text>
                                <!-- Verdict label -->
                                <text id="gauge-label-text" x="100" y="44" text-anchor="middle" font-size="10" font-weight="600" fill="#9ca3af" letter-spacing="0.1em">—</text>
                                <!-- Bar zones clipped to rounded rect -->
                                <clipPath id="bar-clip">
                                    <rect x="20" y="62" width="160" height="10" rx="5"/>
                                </clipPath>
                                <rect x="20" y="62" width="160" height="10" rx="5" fill="#e5e7eb"/>
                                <g clip-path="url(#bar-clip)">
                                    <!-- Green: score 0–5 -->
                                    <rect x="20" y="62" width="53.3333" height="10" fill="#22c55e"/>
                                    <!-- Yellow: score 5–10 -->
                                    <rect x="73.3333" y="62" width="53.3333" height="10" fill="#facc15"/>
                                    <!-- Red: score 10–15+ -->
                                    <rect x="126.6666" y="62" width="53.3334" height="10" fill="#ef4444"/>
                                </g>
                                <!-- Triangle marker pointing down at score position -->
                                <polygon id="gauge-needle" points="100,61 94,53 106,53" fill="#1f2937"/>
                            </svg>
                            <div id="rspamd-action" hidden></div>
                            <div id="rspamd-symbol-count" class="text-[11px] text-neutral-400"></div>
                        </div>
                        <!-- Collapsible symbol breakdown -->
                        <details class="group">
                            <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-2.5 text-[12px] font-medium text-neutral-600 bg-neutral-100 transition-colors hover:bg-neutral-200">
                                <span>Breakdown</span>
                                <svg class="size-3.5 transition-transform group-open:rotate-180" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </summary>
                            <div id="rspamd-chart" class="border-t border-neutral-200"></div>
                        </details>
                    </div>
                </section>


                <!-- Headers -->
                <section class="flex flex-col">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-400 mb-2.5"
                    >
                        Headers
                    </h2>
                    <dl
                        class="overflow-hidden rounded-md border border-neutral-200"
                    >
                        <div
                            class="grid min-h-9 grid-cols-[100px_1fr] items-center"
                        >
                            <dt
                                class="flex h-full items-center border-r border-neutral-200 bg-neutral-50 px-3 text-[12px] text-neutral-400"
                            >
                                Subject
                            </dt>
                            <dd
                                id="r-subject"
                                class="m-0 break-all px-3 py-2 text-[13px] text-neutral-900"
                            >
                            </dd>
                        </div>
                        <div
                            class="grid min-h-9 grid-cols-[100px_1fr] items-center border-t border-neutral-200"
                        >
                            <dt
                                class="flex h-full items-center border-r border-neutral-200 bg-neutral-50 px-3 text-[12px] text-neutral-400"
                            >
                                From
                            </dt>
                            <dd
                                id="r-from"
                                class="m-0 break-all px-3 py-2 text-[13px] text-neutral-900"
                            >
                            </dd>
                        </div>
                        <div
                            class="grid min-h-9 grid-cols-[100px_1fr] items-center border-t border-neutral-200"
                        >
                            <dt
                                class="flex h-full items-center border-r border-neutral-200 bg-neutral-50 px-3 text-[12px] text-neutral-400"
                            >
                                To
                            </dt>
                            <dd
                                id="r-to"
                                class="m-0 break-all px-3 py-2 text-[13px] text-neutral-900"
                            >
                            </dd>
                        </div>
                        <div
                            class="grid min-h-9 grid-cols-[100px_1fr] items-center border-t border-neutral-200"
                        >
                            <dt
                                class="flex h-full items-center border-r border-neutral-200 bg-neutral-50 px-3 text-[12px] text-neutral-400"
                            >
                                Date
                            </dt>
                            <dd
                                id="r-date"
                                class="m-0 break-all px-3 py-2 text-[13px] text-neutral-900"
                            >
                            </dd>
                        </div>
                        <div
                            class="grid min-h-9 grid-cols-[100px_1fr] items-center border-t border-neutral-200"
                        >
                            <dt
                                class="flex h-full items-center border-r border-neutral-200 bg-neutral-50 px-3 text-[12px] text-neutral-400"
                            >
                                Sender IPs
                            </dt>
                            <dd
                                id="r-sender-ips"
                                class="m-0 flex flex-wrap gap-1 px-2 py-2 text-[13px] text-neutral-900"
                            >
                            </dd>
                        </div>
                    </dl>
                    <span
                        class="text-[10px] text-neutral-400 tracking-tight [word-spacing:-0.1rem] mt-0.5"
                        >Emails may gain sender addresses when forwarded through
                        mail networks. The most likely sender addresses are
                        highlighted in yellow.</span
                    >
                </section>

                <!-- Files -->
                <section class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-400"
                    >
                        Files
                    </h2>
                    <dl
                        class="overflow-hidden rounded-md border border-neutral-200"
                    >
                        <div
                            class="grid min-h-9 grid-cols-[100px_1fr] items-center"
                        >
                            <dt
                                class="flex h-full items-center border-r border-neutral-200 bg-neutral-50 px-3 text-[12px] text-neutral-400"
                            >
                                Attachments
                            </dt>
                            <dd
                                id="r-attachments-field"
                                class="m-0 flex flex-wrap items-center gap-1.5 px-3 py-2 text-[13px] text-neutral-900"
                            >
                            </dd>
                        </div>
                    </dl>
                    <div id="sender-origin-section" hidden>
                        <h2 class="font-bold text-xl mb-2">
                            Sender Origin
                        </h2>
                        <div
                            id="sender-origins-list"
                            class="flex flex-col gap-4"
                        ></div>
                        <span
                            class="text-xs m-0 p-0 text-neutral-400 hover:text-neutral-600 transition-colors"
                        >
                            &copy;Mapbox&nbsp;&copy;OpenStreetMap
                        </span>
                    </div>
                </section>
            </div>
        </div>
    </main>
</BaseLayout>

<style>
    /* Spin keyframe for loader — not expressible in Tailwind utilities */
    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
    .loader {
        animation: spin 0.7s linear infinite;
    }

    /* Ensure [hidden] always wins over display utilities */
    [hidden] {
        display: none !important;
    }

    /* flex containers that start hidden — show as flex when unhidden */
    #results:not([hidden]) {
        display: flex;
    }
    #file-chip:not([hidden]) {
        display: flex;
    }
    #loading-row {
        display: flex;
    }

    /* Drag-over state toggled by JS */
    #dropzone.over {
        border-color: #171717;
        background-color: rgba(0, 0, 0, 0.03);
    }

    /* API status colour swaps via data-state attribute */
    #api-status[data-state="online"] {
        border-color: #c3e6d4;
        background-color: #f0faf5;
        color: #1a7f4f;
    }
    #api-status[data-state="online"] #status-dot {
        background-color: #1a7f4f;
    }
    #api-status[data-state="offline"] {
        border-color: #f5c6c2;
        background-color: #fdf3f2;
        color: #c0392b;
    }
    #api-status[data-state="offline"] #status-dot {
        background-color: #c0392b;
    }

    .copyable-cell {
        position: relative;
        cursor: pointer;
        padding-right: 2rem;
        transition: color 0.15s ease;
    }
    .copyable-cell::after {
        content: "⧉";
        position: absolute;
        right: 0.65rem;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0;
        font-size: 16px;
        color: #171717;
        pointer-events: none;
        transition: opacity 0.15s ease;
    }
    .copyable-cell:hover::after {
        opacity: 1;
    }
    .copyable-cell.copied {
        text-decoration: underline dotted;
        text-underline-offset: 2px;
    }
</style>

<script>
    const DEFAULT_API_URL = "https://api.sentinel-systems.cc";
    const STORAGE_KEY = "endpointUrl";

    const endpointInput = document.getElementById(
        "endpointUrl",
    ) as HTMLInputElement;

    const savedUrl = localStorage.getItem(STORAGE_KEY);
    let API_URL = savedUrl || DEFAULT_API_URL;
    if (savedUrl) endpointInput.value = savedUrl;

    let endpointDebounce: number | undefined;

    endpointInput.addEventListener("input", () => {
        clearTimeout(endpointDebounce);

        endpointDebounce = window.setTimeout(() => {
            const newUrl = endpointInput.value.trim();

            API_URL = newUrl || DEFAULT_API_URL;
            if (newUrl) {
                localStorage.setItem(STORAGE_KEY, newUrl);
            } else {
                localStorage.removeItem(STORAGE_KEY);
            }

            checkApi();
        }, 1000);
    });

    const dropzone = document.getElementById("dropzone")!;
    const fileInput = document.getElementById("file-input") as HTMLInputElement;
    const fileChip = document.getElementById("file-chip")!;
    const chipName = document.getElementById("file-chip-name")!;
    const chipSize = document.getElementById("file-chip-size")!;
    const parseBtn = document.getElementById("parse-btn") as HTMLButtonElement;
    const compareBtn = document.getElementById("compare-btn") as HTMLButtonElement;
    const rspamdSection = document.getElementById("rspamd-section")!;
    const rspamdAction = document.getElementById("rspamd-action")!;
    const rspamdSymbolCount = document.getElementById("rspamd-symbol-count")!;
    const rspamdChart = document.getElementById("rspamd-chart")!;
    const inlineError = document.getElementById("inline-error")!;
    const loadingSpinner = document.getElementById("loading-spinner")!;
    const loadingText = document.getElementById("loading-text")!;
    const results = document.getElementById("results")!;
    const apiStatus = document.getElementById("api-status")!;
    const statusText = document.getElementById("status-text")!;
    const uploadHint = document.getElementById("upload-hint")!;
    const senderOriginSection = document.getElementById("sender-origin-section")!;
    const senderOriginsList = document.getElementById("sender-origins-list")!;

    let selectedFile: File | null = null;
    let lastEmailId: string | null = null;
    let lastEmailFrom: string | null = null;
    let lastEmailSubject: string | null = null;
    const DEFAULT_MAX_UPLOAD_BYTES = 0;
    let maxUploadBytes = DEFAULT_MAX_UPLOAD_BYTES;

    function apiPath(path: string) {
        return `${API_URL.replace(/\/$/, "")}${path}`;
    }

    function formatUploadLimit(bytes: number) {
        const megabytes = bytes / (1024 * 1024);
        return Number.isInteger(megabytes)
            ? `${megabytes}MB`
            : `${megabytes.toFixed(1)}MB`;
    }

    function updateUploadLimitText() {
        uploadHint.textContent = maxUploadBytes > 0
            ? `Supports .eml files up to ${formatUploadLimit(maxUploadBytes)}`
            : "Supports .eml files";
    }

    updateUploadLimitText();

    async function refreshMaxUploadSize() {
        try {
            const response = await fetch(apiPath("/max-upload-size"));
            if (!response.ok) throw new Error();

            const data = await response.json();
            const limitInMb = Number(data?.maxUploadSizeMB);

            if (Number.isFinite(limitInMb) && limitInMb > 0) {
                maxUploadBytes = limitInMb * 1024 * 1024;
            }
            updateUploadLimitText();
        } catch {
            maxUploadBytes = DEFAULT_MAX_UPLOAD_BYTES;
            updateUploadLimitText();
        }
    }

    async function checkApi() {
        try {
            const r = await fetch(API_URL);
            if (r.ok) {
                apiStatus.dataset.state = "online";
                statusText.textContent = "API online";
                await refreshMaxUploadSize();
            } else throw new Error();
        } catch {
            apiStatus.dataset.state = "offline";
            statusText.textContent = "API Offline";
        }
    }
    checkApi();
    setInterval(checkApi, 30000);

    function fmt(bytes: number) {
        if (bytes < 1024) return `${bytes} B`;
        if (bytes < 1048576) return `${(bytes / 1024).toFixed(1)} KB`;
        return `${(bytes / 1048576).toFixed(1)} MB`;
    }

    function setFile(file: File) {
        if (!file.name.endsWith(".eml")) {
            showError("Please select a .eml file.");
            return;
        }
        if (maxUploadBytes > 0 && file.size > maxUploadBytes) {
            showError(`File size exceeds ${formatUploadLimit(maxUploadBytes)} limit.`);
            return;
        }
        selectedFile = file;
        chipName.textContent = file.name;
        chipSize.textContent = fmt(file.size);
        fileChip.hidden = false;
        dropzone.hidden = true;
        parseBtn.disabled = false;
        hideError();
        results.hidden = true;
    }

    function clearFile() {
        selectedFile = null;
        fileInput.value = "";
        fileChip.hidden = true;
        dropzone.hidden = false;
        parseBtn.disabled = true;
        results.hidden = true;
        hideError();
    }

    function showError(msg: string) {
        inlineError.textContent = msg;
        inlineError.hidden = false;
    }
    function hideError() {
        inlineError.hidden = true;
    }

    dropzone.addEventListener("click", () => fileInput.click());
    dropzone.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Enter") fileInput.click();
    });
    fileInput.addEventListener("change", () => {
        if (fileInput.files?.[0]) setFile(fileInput.files[0]);
    });
    dropzone.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropzone.classList.add("over");
    });
    dropzone.addEventListener("dragleave", () =>
        dropzone.classList.remove("over"),
    );
    dropzone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropzone.classList.remove("over");
        const file = (e as DragEvent).dataTransfer?.files[0];
        if (file) setFile(file);
    });

    let hasAnalyzed = false;

    parseBtn.addEventListener("click", async () => {
        if (hasAnalyzed) {
            clearFile();
            parseBtn.textContent = "Analyze Email";
            hasAnalyzed = false;
            return;
        }
        if (!selectedFile) return;
        hideError();
        results.hidden = true;
        loadingSpinner.hidden = false;
        loadingText.textContent = "Parsing…";
        parseBtn.disabled = true;

        try {
            const fd = new FormData();
            fd.append("file", selectedFile);
            const res = await fetch(`${API_URL}/parse-email`, {
                method: "POST",
                body: fd,
            });
            const data = await res.json();
            console.log("API response:", data);
            if (!res.ok) throw new Error(data.detail || "Error parsing email.");
            displayResults(data);
        } catch (err: any) {
            showError(err.message || "Could not connect to API.");
        } finally {
            loadingSpinner.hidden = true;
            loadingText.textContent = "";
            parseBtn.disabled = false;
            parseBtn.textContent = "New Email";
            hasAnalyzed = true;
        }
    });

    function set(id: string, val: string) {
        const el = document.getElementById(id);
        if (el) el.textContent = val ?? "—";
    }

    function hasReverseDns(ip: any) {
        return (
            ip?.reverse != null &&
            ip.reverse !== "" &&
            ip.reverse !== "-" &&
            ip.reverse !== "—"
        );
    }

    function escapeHtml(text: string) {
        const element = document.createElement("div");
        element.textContent = text;
        return element.innerHTML;
    }

    function formatSignedScore(value: number) {
        if (!Number.isFinite(value)) return "—";
        return value > 0 ? `+${value.toFixed(2)}` : value.toFixed(2);
    }

    function buildRspamdChart(symbols: Record<string, any>) {
        const contributors = Object.entries(symbols || {})
            .map(([name, value]) => {
                const score = Number(value?.score ?? 0);

                return {
                    name,
                    description: String(value?.description ?? ""),
                    score,
                };
            })
            .filter((entry) => entry.score !== 0)
            .sort((left, right) => Math.abs(right.score) - Math.abs(left.score));

        if (!contributors.length) {
            return '<div class="px-4 py-3 text-[12px] text-neutral-400">No rspamd symbol contributions were returned.</div>';
        }

        const maxAbs = Math.max(
            ...contributors.map((entry) => Math.abs(entry.score)),
            1,
        );

        return contributors
            .map((entry, index) => {
                const widthPct = Math.max((Math.abs(entry.score) / maxAbs) * 50, 3);
                const barColor = entry.score >= 0 ? "bg-red-500" : "bg-emerald-500";
                const labelColor = entry.score >= 0
                    ? "bg-red-50 text-red-700"
                    : "bg-emerald-50 text-emerald-700";
                const barStyle = entry.score >= 0
                    ? `left:50%;width:${widthPct}%;`
                    : `left:${50 - widthPct}%;width:${widthPct}%;`;

                return `
                    <div class="grid grid-cols-[minmax(0,1.35fr)_minmax(180px,2fr)_96px] items-start gap-3 px-4 py-2.5 ${
                        index === 0 ? "" : "border-t border-neutral-200"
                    }">
                        <div class="min-w-0">
                            <div class="truncate text-[12px] font-medium text-neutral-900">${escapeHtml(entry.name)}</div>
                            ${entry.description ? `<div class="text-[10px] text-neutral-400 break-words whitespace-normal leading-relaxed mt-0.5">${escapeHtml(entry.description)}</div>` : ""}
                        </div>
                        <div class="relative h-4 overflow-hidden rounded-full bg-neutral-100 mt-1">
                            <div class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 bg-neutral-300"></div>
                            <div class="absolute top-0 h-full rounded-full ${barColor}" style="${barStyle}"></div>
                        </div>
                        <div class="justify-self-end mt-0.5">
                            <span class="inline-flex rounded-full px-2 py-0.5 text-[11px] font-medium tabular-nums ${labelColor}">${formatSignedScore(entry.score)}</span>
                        </div>
                    </div>`;
            })
            .join("");
    }

    function renderRspamdScore(rspamd: any) {
        const score = Number(rspamd?.score ?? 0);
        const requiredScore = Number(rspamd?.required_score ?? 15);
        const action = String(rspamd?.action ?? "");
        const symbols = rspamd?.symbols || {};
        const contributors = Object.values(symbols).filter((value: any) => {
            const symbolScore = Number(value?.score ?? 0);
            return symbolScore !== 0;
        });

        rspamdSection.hidden = !(rspamd && (Object.keys(symbols).length > 0 || Number.isFinite(score)));
        if (rspamdSection.hidden) return;

        const isClean = score <= 0;
        const isLikelySafe = score > 0 && score < 5;
        const isSuspicious = score >= 5 && score < 10;

        rspamdAction.textContent = action ? `Action: ${action}` : "";
        rspamdSymbolCount.textContent = `${contributors.length} contributing factor${contributors.length === 1 ? "" : "s"}`;

        const maxDisplay   = 15;
        const clampedScore = Math.max(0, Math.min(score, maxDisplay));
        const markerX      = 20 + (clampedScore / maxDisplay) * 160;

        const gaugeNeedle = document.getElementById("gauge-needle")!;
        gaugeNeedle.setAttribute("points", `${markerX.toFixed(1)},61 ${(markerX - 6).toFixed(1)},53 ${(markerX + 6).toFixed(1)},53`);

        const gaugeScoreText = document.getElementById("gauge-score-text")!;
        gaugeScoreText.textContent = Number.isFinite(score) ? score.toFixed(2) : "—";

        const gaugeLabelText = document.getElementById("gauge-label-text")!;
        gaugeLabelText.textContent = isClean
            ? "CLEAN"
            : isLikelySafe
                ? "LIKELY SAFE"
                : isSuspicious
                    ? "SUSPICIOUS"
                    : "HIGH RISK";
        gaugeLabelText.setAttribute(
            "fill",
            isClean
                ? "#16a34a"
                : isLikelySafe
                    ? "#65a30d"
                    : isSuspicious
                        ? "#d97706"
                        : "#ef4444",
        );

        rspamdChart.innerHTML = buildRspamdChart(symbols);
    }

    async function copyTextToClipboard(text: string) {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }

        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.left = "-9999px";
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        document.execCommand("copy");
        document.body.removeChild(textArea);
    }

    function markCellCopied(cell: HTMLElement) {
        cell.classList.add("copied");
        const originalTitle = cell.title;
        cell.title = "Copied";
        setTimeout(() => {
            cell.classList.remove("copied");
            cell.title = originalTitle || "Click to copy";
        }, 900);
    }

    senderOriginsList.addEventListener("click", async (event) => {
        const target = event.target as HTMLElement | null;
        const cell = target?.closest("[data-copy-value]") as HTMLElement | null;
        if (!cell) return;

        const value = cell.dataset.copyValue?.trim();
        if (!value || value === "—") return;

        try {
            await copyTextToClipboard(value);
            markCellCopied(cell);
        } catch {
            showError("Could not copy value to clipboard.");
        }
    });

    function renderOriginRow(label: string, value: any, title?: string) {
        const text = value ?? "—";
        const titleAttr = title ? ` title="${escapeHtml(title)}"` : "";
        const copyValue = escapeHtml(String(text));

        return `
            <tr class="border-b border-neutral-200 last:border-b-0">
                <th class="w-28 bg-neutral-50 px-3 py-2 text-[12px] text-neutral-400 font-medium"${titleAttr}>${escapeHtml(label)}</th>
                <td
                    class="copyable-cell px-3 py-2 text-[13px] text-neutral-900 break-all"
                    title="Click to copy"
                    data-copy-value="${copyValue}"
                >${copyValue}</td>
            </tr>`;
    }

    function renderSenderOrigins(senderIps: any[]) {
        const senderOrigins = Array.isArray(senderIps)
            ? senderIps.filter((ip) => hasReverseDns(ip))
            : [];

        if (!senderOrigins.length && Array.isArray(senderIps)) {
            const fallback = senderIps.find((ip: any) => ip?.map_url);
            if (fallback) senderOrigins.push(fallback);
        }

        if (!senderOrigins.length) {
            senderOriginsList.innerHTML = "";
            senderOriginSection.hidden = true;
            return;
        }

        senderOriginSection.hidden = false;
        senderOriginsList.innerHTML = senderOrigins
            .map((ip: any) => {
                const mapUrl = ip?.map_url ? `${API_URL}${ip.map_url}` : "";
                const originLabel = hasReverseDns(ip) ? "Reverse DNS" : "Map fallback";

                return `
                    <article class="overflow-hidden rounded-md border border-neutral-200 bg-white">
                        <div class="flex flex-wrap items-center justify-between gap-2 border-b border-neutral-200 bg-neutral-50 px-3 py-2">
                            <div class="min-w-0">
                                <div class="truncate text-[13px] font-medium text-neutral-900">${escapeHtml(ip?.query || "—")}</div>
                                <div class="truncate text-[11px] text-neutral-400">${escapeHtml(ip?.reverse || "No reverse DNS")}</div>
                            </div>
                            <span class="rounded-full bg-neutral-200 px-2 py-0.5 text-[11px] font-medium text-neutral-700">${originLabel}</span>
                        </div>
                        <div class="grid gap-4 p-3 lg:grid-cols-[minmax(240px,1fr)_minmax(0,1.1fr)]">
                            <div class="min-h-48 overflow-hidden rounded-xl border border-neutral-200 bg-neutral-100">
                                ${mapUrl ? `<img src="${mapUrl}" class="h-full w-full object-cover" alt="Map showing origin for ${escapeHtml(ip?.query || ip?.reverse || "sender address")}" />` : `<div class="flex h-full items-center justify-center px-4 py-6 text-[12px] text-neutral-400">Map unavailable</div>`}
                            </div>
                            <table class="w-full overflow-hidden rounded-md border border-neutral-200 text-left">
                                <tbody>
                                    ${renderOriginRow("Query", ip?.query)}
                                    ${renderOriginRow("Continent", ip?.continent)}
                                    ${renderOriginRow("Country", ip?.country)}
                                    ${renderOriginRow("Region", ip?.regionName)}
                                    ${renderOriginRow("City", ip?.city)}
                                    ${renderOriginRow("AS Name", ip?.asname || ip?.as)}
                                    ${renderOriginRow("ISP", ip?.isp)}
                                    ${renderOriginRow("Org", ip?.org, "Name of the company that owns this IP address.")}
                                    ${renderOriginRow("Hostname", ip?.reverse, "Name of the server that sent the email.")}
                                </tbody>
                            </table>
                        </div>
                    </article>`;
            })
            .join("");
    }

    function displayResults(data: any) {
        renderRspamdScore(data.rspamd || data.rspamd_assessment);
        set("r-email-id", data.email_id);
        set("r-output-dir", data.output_directory);
        set("r-subject", data.summary.subject);
        set("r-from", data.summary.from);
        set("r-to", data.summary.to);
        set("r-date", data.summary.date);

        const senderIps = data.summary?.sender_ips;
        const senderIpsEl = document.getElementById("r-sender-ips");
        if (senderIpsEl) {
            senderIpsEl.innerHTML = "";

            if (Array.isArray(senderIps) && senderIps.length > 0) {
                senderIps.forEach((ip: any, index: number) => {
                    const query = ip?.query;
                    const hasReverse =
                        ip.reverse != null &&
                        ip.reverse != "" &&
                        ip.reverse !== "-" &&
                        ip.reverse !== "—";

                    const chip = document.createElement("span");
                    chip.className =
                        "inline-flex items-center px-2 py-0.5 text-[12px] text-neutral-900";

                    if (hasReverse) {
                        chip.classList.add("bg-yellow-200");
                        chip.title = `Reverse DNS: ${ip.reverse}`;
                    }
                    chip.textContent = query || "—";
                    if (index < senderIps.length - 1) chip.textContent += ",";
                    senderIpsEl.appendChild(chip);
                });
            } else {
                senderIpsEl.textContent = "—";
            }
        }

        renderSenderOrigins(senderIps);

        const attachmentsField = document.getElementById("r-attachments-field")!;
        attachmentsField.innerHTML = "";

        const attachments = Array.isArray(data.files_created?.attachments)
            ? data.files_created.attachments
            : [];

        if (attachments.length === 0) {
            attachmentsField.textContent = "No attachments found";
        } else {
            const statusMeta: Record<string, { bg: string; border: string; color: string; dot: string; symbol: string; label: (t?: string, e?: string) => string }> = {
                clean:    { bg: "#dafbe1", border: "#9fcea9", color: "#1a7f37", dot: "#2da44e", symbol: "✓", label: () => "Clean" },
                infected: { bg: "#ffd8d3", border: "#f5a9a3", color: "#cf222e", dot: "#cf222e", symbol: "✕", label: (t) => t ? `Infected: ${t}` : "Infected" },
                error:    { bg: "#fff8c5", border: "#d4a520", color: "#9a6700", dot: "#bf8700", symbol: "⚠", label: (_t, e) => e ? `Error: ${e}` : "Scan Error" },
                unknown:  { bg: "#f6f8fa", border: "#d0d7de", color: "#57606a", dot: "#8c959f", symbol: "●", label: () => "Unknown" },
            };

            attachments.forEach((attachment: any) => {
                const filename = attachment.filename || attachment;
                const clamavStatus = attachment.clamav?.status || "unknown";
                const threat = attachment.clamav?.threat;
                const errorDetail = attachment.clamav?.detail;

                const meta = statusMeta[clamavStatus] ?? statusMeta.unknown;
                const labelText = meta.label(threat, errorDetail);

                const group = document.createElement("span");
                group.className = "inline-flex items-center gap-1 flex-shrink-0";

                // Filename chip — always neutral
                const nameChip = document.createElement("span");
                nameChip.style.cssText = "background:#f6f8fa;border:1px solid #d0d7de;color:#24292f;";
                nameChip.className = "inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-medium max-w-[220px]";

                const fileIcon = document.createElement("span");
                fileIcon.textContent = "📄";
                fileIcon.className = "text-[10px] shrink-0";

                const nameText = document.createElement("span");
                nameText.className = "truncate";
                nameText.title = String(filename);
                nameText.textContent = String(filename);

                nameChip.appendChild(fileIcon);
                nameChip.appendChild(nameText);

                // Status chip — colored per scan result
                const statusChip = document.createElement("span");
                statusChip.style.cssText = `background:${meta.bg};border:1px solid ${meta.border};color:${meta.color};`;
                statusChip.className = "inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-semibold shrink-0";

                const dot = document.createElement("span");
                dot.style.cssText = `color:${meta.dot};`;
                dot.className = "text-[10px] leading-none";
                dot.textContent = meta.symbol;

                const statusText = document.createElement("span");
                statusText.textContent = labelText;

                statusChip.appendChild(dot);
                statusChip.appendChild(statusText);

                group.appendChild(nameChip);
                group.appendChild(statusChip);
                attachmentsField.appendChild(group);
            });
        }

        results.hidden = false;

        // Store email data for comparison workflow
        lastEmailId = data.email_id || null;
        lastEmailFrom = data.summary?.from || null;
        lastEmailSubject = data.summary?.subject || null;
        compareBtn.hidden = false;
    }

    // Navigate to diff page with email parameters
    compareBtn.addEventListener("click", () => {
        if (!lastEmailId) return;

        const params = new URLSearchParams();
        params.set("suspicious_email_id", lastEmailId);
        if (lastEmailFrom) params.set("from", lastEmailFrom);
        if (lastEmailSubject) params.set("subject", lastEmailSubject);

        window.location.href = `./diff?${params.toString()}`;
    });
</script>
