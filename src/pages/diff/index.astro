---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { url } from "../../scripts/url";
---

<BaseLayout
    title="Diff Check — Sentinel Systems"
    description="Compare a suspicious email against a known-legitimate one. Detect spoofing, impersonation, and authentication anomalies side-by-side."
>
    <main class="flex items-start justify-center px-6 md:px-20 lg:px-40 py-12">
        <div class="flex w-full max-w-270 flex-col gap-5">
            <!-- Page header -->
            <div class="mb-1">
                <div class="flex items-center gap-2 mb-1.5">
                    <a
                        href={url("/")}
                        class="text-[12px] text-neutral-500 hover:text-neutral-600 transition-colors no-underline"
                        >&larr; Back to Analyzer</a
                    >
                </div>
                <h1 class="mb-1.5 text-[22px] font-semibold text-neutral-900">
                    Diff Check
                </h1>
                <p class="text-[13px] leading-relaxed text-neutral-500">
                    Compare a suspicious email against a known-legitimate one to
                    detect spoofing, impersonation, and authentication
                    anomalies.
                </p>
            </div>

            <div class="grid">
                <label for="endpointUrl">Endpoint URL</label>
                <input
                    id="endpointUrl"
                    class="w-full bg-neutral-100 px-3 py-2 rounded-md border border-neutral-200"
                    type="text"
                    placeholder="https://api.sentinel-systems.cc/"
                />
                <span class="text-neutral-500 text-xs"
                    >For development purposes only.</span
                >
            </div>

            <!-- API status -->
            <div
                id="api-status"
                class="flex items-center gap-2 rounded-md border border-neutral-200 bg-neutral-100 px-3 py-2 text-[12px] text-neutral-500"
                data-state="checking"
            >
                <span
                    id="status-dot"
                    class="size-1.75 shrink-0 rounded-full bg-neutral-400 transition-colors"
                ></span>
                <span id="status-text">Checking API…</span>
            </div>

            <!-- ─── Step 1: Suspicious email ─── -->
            <section class="flex flex-col gap-2.5">
                <h2
                    class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                >
                    Step 1 — Suspicious Email
                </h2>

                <!-- Pre-filled from parser page -->
                <div
                    id="suspicious-prefilled"
                    hidden
                    class="flex flex-col gap-1.5 rounded-md border border-neutral-200 bg-neutral-50 px-3 py-2.5"
                >
                    <div
                        class="flex items-center justify-between text-[13px]"
                    >
                        <div class="flex items-center gap-2">
                            <span
                                class="size-1.75 shrink-0 rounded-full bg-amber-500"
                            ></span>
                            <span class="font-medium text-neutral-900"
                                >Suspicious email loaded</span
                            >
                        </div>
                        <button
                            id="clear-suspicious"
                            class="text-[11px] text-neutral-500 hover:text-red-600 cursor-pointer bg-transparent border-0 transition-colors"
                            >Clear</button
                        >
                    </div>
                    <dl
                        class="m-0 grid grid-cols-[60px_1fr] gap-x-2 gap-y-0.5 text-[12px]"
                    >
                        <dt class="text-neutral-500">ID</dt>
                        <dd
                            id="susp-prefill-id"
                            class="m-0 text-neutral-600 break-all"
                        >
                        </dd>
                        <dt class="text-neutral-500">From</dt>
                        <dd
                            id="susp-prefill-from"
                            class="m-0 text-neutral-600 break-all"
                        >
                        </dd>
                        <dt class="text-neutral-500">Subject</dt>
                        <dd
                            id="susp-prefill-subject"
                            class="m-0 text-neutral-600 break-all"
                        >
                        </dd>
                    </dl>
                </div>

                <!-- Manual upload fallback -->
                <div id="suspicious-upload-zone" class="flex flex-col gap-2.5">
                    <div
                        id="dropzone-suspicious"
                        role="button"
                        tabindex="0"
                        aria-label="Upload suspicious EML file"
                        class="cursor-pointer rounded-md border border-dashed border-neutral-300 bg-neutral-50 px-6 py-7 text-center transition-colors hover:border-neutral-900 hover:bg-black/3"
                    >
                        <input
                            type="file"
                            id="file-input-suspicious"
                            accept=".eml"
                            class="hidden"
                        />
                        <div class="mb-2 inline-flex text-neutral-500">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 20 20"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M10 2L10 13M10 2L6.5 5.5M10 2L13.5 5.5"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                                <path
                                    d="M3 14V16C3 17.1046 3.89543 18 5 18H15C16.1046 18 17 17.1046 17 16V14"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    stroke-linecap="round"></path>
                            </svg>
                        </div>
                        <p class="mb-1 text-[13px] text-neutral-500">
                            Drop <strong>suspicious</strong> email here or <span
                                class="cursor-pointer text-neutral-900 underline underline-offset-2"
                                >browse</span
                            >.
                        </p>
                        <p class="text-[11px] text-neutral-500">
                            Supports .eml files up to 50MB
                        </p>
                    </div>

                    <!-- File chip (suspicious) -->
                    <div
                        id="file-chip-suspicious"
                        hidden
                        class="items-center gap-2 rounded-md border border-neutral-200 bg-neutral-100 px-3 py-2 text-[13px] text-neutral-900"
                    >
                        <svg
                            class="shrink-0 text-neutral-500"
                            width="14"
                            height="14"
                            viewBox="0 0 14 14"
                            fill="none"
                        >
                            <rect
                                x="2"
                                y="1"
                                width="8"
                                height="12"
                                rx="1"
                                stroke="currentColor"
                                stroke-width="1.2"></rect>
                            <path
                                d="M4 4.5H8M4 7H8M4 9.5H6.5"
                                stroke="currentColor"
                                stroke-width="1.2"
                                stroke-linecap="round"></path>
                        </svg>
                        <span id="chip-name-suspicious"></span>
                        <span
                            id="chip-size-suspicious"
                            class="ml-0.5 text-[11px] text-neutral-500"></span>
                        <button
                            id="chip-remove-suspicious"
                            aria-label="Remove file"
                            class="ml-auto cursor-pointer rounded border-0 bg-transparent px-1 py-0.5 text-[16px] leading-none text-neutral-500 transition-colors hover:bg-red-50 hover:text-red-600"
                            >✕</button
                        >
                    </div>
                </div>
            </section>

            <!-- ─── Step 2: Legitimate email ─── -->
            <section class="flex flex-col gap-2.5">
                <h2
                    class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                >
                    Step 2 — Legitimate Email
                </h2>

                <div
                    id="dropzone-legitimate"
                    role="button"
                    tabindex="0"
                    aria-label="Upload legitimate EML file"
                    class="cursor-pointer rounded-md border border-dashed border-neutral-300 bg-neutral-50 px-6 py-7 text-center transition-colors hover:border-neutral-900 hover:bg-black/3"
                >
                    <input
                        type="file"
                        id="file-input-legitimate"
                        accept=".eml"
                        class="hidden"
                    />
                    <div class="mb-2 inline-flex text-neutral-500">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 20 20"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M10 2L10 13M10 2L6.5 5.5M10 2L13.5 5.5"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                            <path
                                d="M3 14V16C3 17.1046 3.89543 18 5 18H15C16.1046 18 17 17.1046 17 16V14"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"></path>
                        </svg>
                    </div>
                    <p class="mb-1 text-[13px] text-neutral-500">
                        Drop <strong>legitimate</strong> email here or <span
                            class="cursor-pointer text-neutral-900 underline underline-offset-2"
                            >browse</span
                        >.
                    </p>
                    <p class="text-[11px] text-neutral-500">
                        Supports .eml files up to 50MB
                    </p>
                </div>

                <!-- File chip (legitimate) -->
                <div
                    id="file-chip-legitimate"
                    hidden
                    class="items-center gap-2 rounded-md border border-neutral-200 bg-neutral-100 px-3 py-2 text-[13px] text-neutral-900"
                >
                    <svg
                        class="shrink-0 text-neutral-500"
                        width="14"
                        height="14"
                        viewBox="0 0 14 14"
                        fill="none"
                    >
                        <rect
                            x="2"
                            y="1"
                            width="8"
                            height="12"
                            rx="1"
                            stroke="currentColor"
                            stroke-width="1.2"></rect>
                        <path
                            d="M4 4.5H8M4 7H8M4 9.5H6.5"
                            stroke="currentColor"
                            stroke-width="1.2"
                            stroke-linecap="round"></path>
                    </svg>
                    <span id="chip-name-legitimate"></span>
                    <span
                        id="chip-size-legitimate"
                        class="ml-0.5 text-[11px] text-neutral-500"></span>
                    <button
                        id="chip-remove-legitimate"
                        aria-label="Remove file"
                        class="ml-auto cursor-pointer rounded border-0 bg-transparent px-1 py-0.5 text-[16px] leading-none text-neutral-500 transition-colors hover:bg-red-50 hover:text-red-600"
                        >✕</button
                    >
                </div>
            </section>

            <!-- Compare button -->
            <button
                id="compare-btn"
                disabled
                class="w-full cursor-pointer rounded-md border-0 bg-neutral-900 px-4 py-2.5 text-[14px] font-medium tracking-wide text-white transition-opacity active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-30 enabled:hover:opacity-85"
            >
                Compare Emails
            </button>

            <!-- Error -->
            <div
                id="inline-error"
                hidden
                class="rounded-md border border-red-200 bg-red-50 px-3 py-2.5 text-[13px] text-red-700"
            >
            </div>

            <!-- ─── Workflow progress ─── -->
            <div id="workflow" hidden class="flex flex-col gap-0">
                <!-- Step: Parse -->
                <div
                    id="wf-parse"
                    class="wf-step flex items-start gap-3 pb-4"
                    data-status="pending"
                >
                    <div class="flex flex-col items-center gap-0 pt-px">
                        <div
                            class="wf-icon size-5 shrink-0 rounded-full border border-neutral-300 bg-white flex items-center justify-center text-[10px] text-neutral-500 transition-all"
                        >
                        </div>
                        <div
                            class="wf-connector w-px flex-1 bg-neutral-200 mt-1"
                        >
                        </div>
                    </div>
                    <div class="flex flex-col gap-0.5 min-w-0">
                        <div class="flex items-center gap-2">
                            <span
                                class="wf-label text-[13px] font-medium text-neutral-500"
                                >Analyzing emails</span
                            >
                            <span
                                class="wf-timer text-[11px] tabular-nums text-neutral-300"
                            ></span>
                        </div>
                        <span
                            class="wf-detail text-[11px] text-neutral-500"
                        ></span>
                    </div>
                </div>

                <!-- Step: Compare -->
                <div
                    id="wf-compare"
                    class="wf-step flex items-start gap-3"
                    data-status="pending"
                >
                    <div class="flex flex-col items-center gap-0 pt-px">
                        <div
                            class="wf-icon size-5 shrink-0 rounded-full border border-neutral-300 bg-white flex items-center justify-center text-[10px] text-neutral-500 transition-all"
                        >
                        </div>
                    </div>
                    <div class="flex flex-col gap-0.5 min-w-0">
                        <div class="flex items-center gap-2">
                            <span
                                class="wf-label text-[13px] font-medium text-neutral-500"
                                >Compare emails</span
                            >
                            <span
                                class="wf-timer text-[11px] tabular-nums text-neutral-300"
                            ></span>
                        </div>
                        <span
                            class="wf-detail text-[11px] text-neutral-500"
                        ></span>
                    </div>
                </div>
            </div>

            <!-- ─── Results ─── -->
            <div id="results" hidden class="flex-col gap-6">
                <div class="h-px bg-neutral-200"></div>

                <!-- Risk verdict -->
                <section id="risk-section" class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                    >
                        Risk Assessment
                    </h2>
                    <div
                        id="risk-banner"
                        class="flex items-center gap-3 rounded-md border px-4 py-3"
                    >
                        <div class="flex flex-col gap-0.5">
                            <div class="flex items-center gap-2">
                                <span
                                    id="risk-dot"
                                    class="size-2 shrink-0 rounded-full"></span>
                                <span
                                    id="risk-level"
                                    class="text-[14px] font-semibold uppercase tracking-wide"
                                ></span>
                                <span
                                    id="risk-score-badge"
                                    class="text-[11px] px-1.5 py-px rounded-full bg-neutral-200 text-neutral-500"
                                ></span>
                            </div>
                            <p
                                id="risk-verdict"
                                class="text-[13px] m-0 leading-snug"
                            >
                            </p>
                        </div>
                    </div>
                </section>

                <!-- Anomalies -->
                <section id="anomalies-section" hidden class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                    >
                        Anomalies
                    </h2>
                    <details id="anomalies-details" class="group overflow-hidden rounded-md border border-neutral-200">
                        <summary
                            id="anomalies-summary"
                            class="flex cursor-pointer list-none items-center justify-between px-3 py-2.5 text-[12px] font-medium text-neutral-600 bg-neutral-100 transition-colors hover:bg-neutral-200"
                        >
                            <span id="anomalies-summary-text"
                                >View all anomalies (0)</span
                            >
                            <svg class="size-3.5 transition-transform group-open:rotate-180" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </summary>
                        <ul
                            id="anomalies-list"
                            class="m-0 flex list-none flex-col gap-1 border-t border-neutral-200 p-2"
                        >
                        </ul>
                    </details>
                </section>

                <!-- Auth comparison -->
                <section class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                    >
                        Authentication
                    </h2>
                    <div class="flex gap-3 flex-wrap">
                        <div
                            class="flex-1 min-w-35 rounded-md border border-neutral-200 px-3 py-2.5"
                        >
                            <div
                                class="text-[10px] uppercase tracking-wide text-neutral-500 mb-0.5"
                            >
                                Suspicious score
                            </div>
                            <div
                                id="auth-susp-score"
                                class="text-[18px] font-semibold text-neutral-900 tabular-nums"
                            >
                            </div>
                            <div
                                id="auth-susp-action"
                                class="text-[11px] text-neutral-500"
                            >
                            </div>
                        </div>
                        <div
                            class="flex-1 min-w-35 rounded-md border border-neutral-200 px-3 py-2.5"
                        >
                            <div
                                class="text-[10px] uppercase tracking-wide text-neutral-500 mb-0.5"
                            >
                                Legitimate score
                            </div>
                            <div
                                id="auth-legit-score"
                                class="text-[18px] font-semibold text-neutral-900 tabular-nums"
                            >
                            </div>
                            <div
                                id="auth-legit-action"
                                class="text-[11px] text-neutral-500"
                            >
                            </div>
                        </div>
                        <div
                            id="deltaBox"
                            class="flex-1 min-w-35 rounded-md border border-neutral-200 px-3 py-2.5"
                        >
                            <div
                                class="text-[10px] uppercase tracking-wide text-neutral-500 mb-0.5"
                            >
                                Score delta
                            </div>
                            <div
                                id="auth-delta"
                                class="text-[18px] font-semibold tabular-nums"
                            >
                            </div>
                            <div class="text-[11px] text-neutral-500">
                                suspicious - legitimate
                            </div>
                        </div>
                    </div>
                    <details id="auth-symbols-details" class="group overflow-hidden rounded-md border border-neutral-200">
                        <summary
                            id="auth-symbols-summary"
                            class="flex cursor-pointer list-none items-center justify-between px-3 py-2.5 text-[12px] font-medium text-neutral-600 bg-neutral-100 transition-colors hover:bg-neutral-200"
                        >
                            <span id="auth-symbols-summary-text"
                                >View all symbols (0)</span
                            >
                            <svg class="size-3.5 transition-transform group-open:rotate-180" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </summary>
                        <div
                            id="auth-symbols-wrap"
                            class="border-t border-neutral-200"
                        >
                        </div>
                    </details>
                </section>

                <!-- Header comparison -->
                <section class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                    >
                        Header Comparison
                    </h2>
                    <div
                        id="header-table-wrap"
                        class="overflow-hidden rounded-md border border-neutral-200"
                    >
                    </div>
                </section>

                <!-- IP / Geo comparison -->
                <section class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                    >
                        IP / Geolocation
                    </h2>
                    <div class="flex gap-3 flex-wrap">
                        <div
                            class="flex-1 min-w-35 rounded-md border border-neutral-200 px-3 py-2.5"
                        >
                            <div
                                class="text-[10px] uppercase tracking-wide text-neutral-500 mb-0.5"
                            >
                                Shared IPs
                            </div>
                            <div
                                id="ip-shared-count"
                                class="text-[18px] font-semibold text-neutral-900 tabular-nums"
                            >
                            </div>
                        </div>
                        <div
                            class="flex-1 min-w-35 rounded-md border border-neutral-200 px-3 py-2.5"
                        >
                            <div
                                class="text-[10px] uppercase tracking-wide text-neutral-500 mb-0.5"
                            >
                                Suspicious only
                            </div>
                            <div
                                id="ip-susp-only-count"
                                class="text-[18px] font-semibold text-neutral-900 tabular-nums"
                            >
                            </div>
                        </div>
                        <div
                            class="flex-1 min-w-35 rounded-md border border-neutral-200 px-3 py-2.5"
                        >
                            <div
                                class="text-[10px] uppercase tracking-wide text-neutral-500 mb-0.5"
                            >
                                Legitimate only
                            </div>
                            <div
                                id="ip-legit-only-count"
                                class="text-[18px] font-semibold text-neutral-900 tabular-nums"
                            >
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-2 flex-wrap items-center">
                        <div
                            id="ip-susp-countries"
                            class="text-[12px] text-neutral-500"
                        >
                        </div>
                        <span class="text-neutral-500">-</span>
                        <div
                            id="ip-legit-countries"
                            class="text-[12px] text-neutral-500"
                        >
                        </div>
                    </div>

                    <div
                        id="ip-geo-table-wrap"
                        class="overflow-hidden rounded-md border border-neutral-200"
                    >
                    </div>
                </section>

                <!-- Body similarity -->
                <section class="flex flex-col gap-2.5">
                    <h2
                        class="text-[11px] font-semibold uppercase tracking-widest text-neutral-500"
                    >
                        Body Similarity
                    </h2>
                    <div
                        class="rounded-md border border-neutral-200 px-3 py-2.5 flex items-center gap-3"
                    >
                        <div class="flex flex-col gap-0.5">
                            <div class="flex items-center gap-2">
                                <span
                                    id="body-ratio"
                                    class="text-[18px] font-semibold text-neutral-900 tabular-nums"
                                ></span>
                                <span
                                    id="body-interp"
                                    class="text-[11px] px-1.5 py-px rounded-full"
                                ></span>
                            </div>
                            <p
                                id="body-note"
                                class="text-[12px] text-neutral-500 m-0"
                            >
                            </p>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>
</BaseLayout>

<style>
    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
    .loader {
        animation: spin 0.7s linear infinite;
    }
    [hidden] {
        display: none !important;
    }
    #results:not([hidden]) {
        display: flex;
    }
    #file-chip-suspicious:not([hidden]),
    #file-chip-legitimate:not([hidden]) {
        display: flex;
    }
    #suspicious-prefilled:not([hidden]) {
        display: flex;
    }
    #workflow:not([hidden]) {
        display: flex;
    }
    #anomalies-section:not([hidden]) {
        display: flex;
    }

    /* Dropzone drag-over */
    .dropzone-active {
        border-color: #171717 !important;
        background-color: rgba(0, 0, 0, 0.03) !important;
    }

    /* API status colour swaps */
    #api-status[data-state="online"] {
        border-color: #c3e6d4;
        background-color: #f0faf5;
        color: #1a7f4f;
    }
    #api-status[data-state="online"] #status-dot {
        background-color: #1a7f4f;
    }
    #api-status[data-state="offline"] {
        border-color: #f5c6c2;
        background-color: #fdf3f2;
        color: #c0392b;
    }
    #api-status[data-state="offline"] #status-dot {
        background-color: #c0392b;
    }

    /* ── Workflow step states ── */
    .wf-step[data-status="pending"] .wf-icon {
        border-color: #d4d4d4;
        background: white;
    }
    .wf-step[data-status="pending"] .wf-label {
        color: #a3a3a3;
    }

    .wf-step[data-status="running"] .wf-icon {
        border-color: #171717;
        background: white;
    }
    .wf-step[data-status="running"] .wf-icon::after {
        content: "";
        display: block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid transparent;
        border-top-color: #171717;
        animation: spin 0.7s linear infinite;
    }
    .wf-step[data-status="running"] .wf-label {
        color: #171717;
    }
    .wf-step[data-status="running"] .wf-timer {
        color: #737373;
    }

    .wf-step[data-status="done"] .wf-icon {
        border-color: #16a34a;
        background: #16a34a;
    }
    .wf-step[data-status="done"] .wf-icon::after {
        content: "✓";
        color: white;
        font-size: 10px;
        line-height: 1;
    }
    .wf-step[data-status="done"] .wf-label {
        color: #737373;
    }
    .wf-step[data-status="done"] .wf-timer {
        color: #a3a3a3;
    }

    .wf-step[data-status="error"] .wf-icon {
        border-color: #dc2626;
        background: #dc2626;
    }
    .wf-step[data-status="error"] .wf-icon::after {
        content: "✕";
        color: white;
        font-size: 10px;
        line-height: 1;
    }
    .wf-step[data-status="error"] .wf-label {
        color: #dc2626;
    }

    /* Risk banner colour variants */
    .risk-clean {
        border-color: #c3c3c3;
        background-color: #f0f0f0;
    }
    .risk-clean #risk-dot {
        display: hidden;
    }
    .risk-clean #risk-level {
        color: #656565;
    }
    .risk-clean #risk-verdict {
        color: #7c7c7c;
    }

    .risk-low {
        border-color: #c3e6d4;
        background-color: #f0faf5;
    }
    .risk-low #risk-dot {
        background-color: #16a34a;
    }
    .risk-low #risk-level {
        color: #15803d;
    }
    .risk-low #risk-verdict {
        color: #166534;
    }

    .risk-medium {
        border-color: #fde68a;
        background-color: #fefce8;
    }
    .risk-medium #risk-dot {
        background-color: #ca8a04;
    }
    .risk-medium #risk-level {
        color: #a16207;
    }
    .risk-medium #risk-verdict {
        color: #854d0e;
    }

    .risk-high {
        border-color: #fed7aa;
        background-color: #fff7ed;
    }
    .risk-high #risk-dot {
        background-color: #ea580c;
    }
    .risk-high #risk-level {
        color: #c2410c;
    }
    .risk-high #risk-verdict {
        color: #9a3412;
    }

    .risk-critical {
        border-color: #f5c6c2;
        background-color: #fdf3f2;
    }
    .risk-critical #risk-dot {
        background-color: #dc2626;
    }
    .risk-critical #risk-level {
        color: #dc2626;
    }
    .risk-critical #risk-verdict {
        color: #991b1b;
    }
</style>

<script>
    // ───────────────────────────────────
    //  Config & DOM refs
    // ───────────────────────────────────
    const DEFAULT_API_URL = "https://api.sentinel-systems.cc";
    const STORAGE_KEY = "endpointUrl";

    const endpointInput = document.getElementById(
        "endpointUrl",
    ) as HTMLInputElement;
    const savedUrl = localStorage.getItem(STORAGE_KEY);
    let API_URL = savedUrl || DEFAULT_API_URL;
    if (savedUrl) endpointInput.value = savedUrl;

    let endpointDebounce: number | undefined;
    endpointInput.addEventListener("input", () => {
        clearTimeout(endpointDebounce);
        endpointDebounce = window.setTimeout(() => {
            const v = endpointInput.value.trim();
            API_URL = v || DEFAULT_API_URL;
            v
                ? localStorage.setItem(STORAGE_KEY, v)
                : localStorage.removeItem(STORAGE_KEY);
            checkApi();
        }, 1000);
    });

    const apiStatus = document.getElementById("api-status")!;
    const statusText = document.getElementById("status-text")!;
    const compareBtn = document.getElementById(
        "compare-btn",
    ) as HTMLButtonElement;
    const inlineError = document.getElementById("inline-error")!;
    const workflow = document.getElementById("workflow")!;
    const wfParse = document.getElementById("wf-parse")!;
    const wfCompare = document.getElementById("wf-compare")!;
    const resultsEl = document.getElementById("results")!;

    // Suspicious — prefilled vs upload
    const suspPrefilled = document.getElementById("suspicious-prefilled")!;
    const suspUploadZone = document.getElementById("suspicious-upload-zone")!;
    const dropzoneSusp = document.getElementById("dropzone-suspicious")!;
    const fileInputSusp = document.getElementById(
        "file-input-suspicious",
    ) as HTMLInputElement;
    const chipSusp = document.getElementById("file-chip-suspicious")!;
    const chipNameSusp = document.getElementById("chip-name-suspicious")!;
    const chipSizeSusp = document.getElementById("chip-size-suspicious")!;
    const chipRemoveSusp = document.getElementById("chip-remove-suspicious")!;
    const clearSuspBtn = document.getElementById("clear-suspicious")!;

    // Legitimate
    const dropzoneLegit = document.getElementById("dropzone-legitimate")!;
    const fileInputLegit = document.getElementById(
        "file-input-legitimate",
    ) as HTMLInputElement;
    const chipLegit = document.getElementById("file-chip-legitimate")!;
    const chipNameLegit = document.getElementById("chip-name-legitimate")!;
    const chipSizeLegit = document.getElementById("chip-size-legitimate")!;
    const chipRemoveLegit = document.getElementById("chip-remove-legitimate")!;

    // ───────────────────────────────────
    //  State
    // ───────────────────────────────────
    let suspiciousEmailId: string | null = null;
    let suspiciousFile: File | null = null;
    let legitimateFile: File | null = null;
    const MAX_UPLOAD_BYTES = 50 * 1024 * 1024;

    // ───────────────────────────────────
    //  API check
    // ───────────────────────────────────
    async function checkApi() {
        try {
            const r = await fetch(API_URL);
            if (r.ok) {
                apiStatus.dataset.state = "online";
                statusText.textContent = "API online";
            } else throw new Error();
        } catch {
            apiStatus.dataset.state = "offline";
            statusText.textContent = "API Offline";
        }
    }
    checkApi();
    setInterval(checkApi, 30000);

    // ───────────────────────────────────
    //  Utilities
    // ───────────────────────────────────
    function fmt(bytes: number) {
        if (bytes < 1024) return `${bytes} B`;
        if (bytes < 1048576) return `${(bytes / 1024).toFixed(1)} KB`;
        return `${(bytes / 1048576).toFixed(1)} MB`;
    }

    function showError(msg: string) {
        inlineError.textContent = msg;
        inlineError.hidden = false;
    }
    function hideError() {
        inlineError.hidden = true;
    }

    function updateCompareBtn() {
        const hasSusp = suspiciousEmailId !== null || suspiciousFile !== null;
        const hasLegit = legitimateFile !== null;
        compareBtn.disabled = !(hasSusp && hasLegit);
    }

    // ───────────────────────────────────
    //  Prefill from URL params
    // ───────────────────────────────────
    const params = new URLSearchParams(window.location.search);
    const prefilledId = params.get("suspicious_email_id");
    const prefilledFrom = params.get("from");
    const prefilledSubject = params.get("subject");

    if (prefilledId) {
        suspiciousEmailId = prefilledId;
        document.getElementById("susp-prefill-id")!.textContent = prefilledId;
        document.getElementById("susp-prefill-from")!.textContent =
            prefilledFrom || "—";
        document.getElementById("susp-prefill-subject")!.textContent =
            prefilledSubject || "—";
        suspPrefilled.hidden = false;
        suspUploadZone.hidden = true;
        updateCompareBtn();
    }

    clearSuspBtn.addEventListener("click", () => {
        suspiciousEmailId = null;
        suspPrefilled.hidden = true;
        suspUploadZone.hidden = false;
        // Also clear URL params silently
        const url = new URL(window.location.href);
        url.searchParams.delete("suspicious_email_id");
        url.searchParams.delete("from");
        url.searchParams.delete("subject");
        history.replaceState(null, "", url.toString());
        updateCompareBtn();
    });

    // ───────────────────────────────────
    //  Dropzone wiring (generic helper)
    // ───────────────────────────────────
    function wireDropzone(
        zone: HTMLElement,
        input: HTMLInputElement,
        chip: HTMLElement,
        chipName: HTMLElement,
        chipSize: HTMLElement,
        chipRemove: HTMLElement,
        onSet: (file: File) => void,
        onClear: () => void,
    ) {
        zone.addEventListener("click", () => input.click());
        zone.addEventListener("keydown", (e) => {
            if ((e as KeyboardEvent).key === "Enter") input.click();
        });
        input.addEventListener("change", () => {
            if (input.files?.[0]) pickFile(input.files[0]);
        });
        zone.addEventListener("dragover", (e) => {
            e.preventDefault();
            zone.classList.add("dropzone-active");
        });
        zone.addEventListener("dragleave", () =>
            zone.classList.remove("dropzone-active"),
        );
        zone.addEventListener("drop", (e) => {
            e.preventDefault();
            zone.classList.remove("dropzone-active");
            const f = (e as DragEvent).dataTransfer?.files[0];
            if (f) pickFile(f);
        });
        chipRemove.addEventListener("click", () => {
            input.value = "";
            chip.hidden = true;
            zone.hidden = false;
            onClear();
            updateCompareBtn();
        });

        function pickFile(file: File) {
            if (!file.name.endsWith(".eml")) {
                showError("Please select a .eml file.");
                return;
            }
            if (file.size > MAX_UPLOAD_BYTES) {
                showError("File size exceeds 50MB limit.");
                return;
            }
            hideError();
            chipName.textContent = file.name;
            chipSize.textContent = fmt(file.size);
            chip.hidden = false;
            zone.hidden = true;
            onSet(file);
            updateCompareBtn();
        }
    }

    wireDropzone(
        dropzoneSusp,
        fileInputSusp,
        chipSusp,
        chipNameSusp,
        chipSizeSusp,
        chipRemoveSusp,
        (f) => {
            suspiciousFile = f;
            suspiciousEmailId = null;
        },
        () => {
            suspiciousFile = null;
        },
    );

    wireDropzone(
        dropzoneLegit,
        fileInputLegit,
        chipLegit,
        chipNameLegit,
        chipSizeLegit,
        chipRemoveLegit,
        (f) => {
            legitimateFile = f;
        },
        () => {
            legitimateFile = null;
        },
    );

    // ───────────────────────────────────
    //  Workflow timer
    // ───────────────────────────────────
    function createTimer(stepEl: HTMLElement) {
        const timerEl = stepEl.querySelector(".wf-timer") as HTMLElement;
        const detailEl = stepEl.querySelector(".wf-detail") as HTMLElement;
        let start = 0;
        let raf = 0;

        function tick() {
            const elapsed = ((performance.now() - start) / 1000).toFixed(1);
            timerEl.textContent = `${elapsed}s`;
            raf = requestAnimationFrame(tick);
        }

        return {
            start(detail?: string) {
                stepEl.dataset.status = "running";
                if (detail) detailEl.textContent = detail;
                start = performance.now();
                tick();
            },
            done(detail?: string) {
                cancelAnimationFrame(raf);
                const elapsed = ((performance.now() - start) / 1000).toFixed(1);
                timerEl.textContent = `${elapsed}s`;
                stepEl.dataset.status = "done";
                if (detail) detailEl.textContent = detail;
            },
            error(detail?: string) {
                cancelAnimationFrame(raf);
                stepEl.dataset.status = "error";
                if (detail) detailEl.textContent = detail;
            },
        };
    }

    // ───────────────────────────────────
    //  Compare flow
    // ───────────────────────────────────
    compareBtn.addEventListener("click", async () => {
        if (!legitimateFile) return;
        if (!suspiciousEmailId && !suspiciousFile) return;

        hideError();
        resultsEl.hidden = true;
        workflow.hidden = false;

        // Reset workflow
        wfParse.dataset.status = "pending";
        wfCompare.dataset.status = "pending";
        (wfParse.querySelector(".wf-timer") as HTMLElement).textContent = "";
        (wfCompare.querySelector(".wf-timer") as HTMLElement).textContent = "";
        (wfParse.querySelector(".wf-detail") as HTMLElement).textContent = "";
        (wfCompare.querySelector(".wf-detail") as HTMLElement).textContent = "";

        compareBtn.disabled = true;

        const parseTimer = createTimer(wfParse);
        const compareTimer = createTimer(wfCompare);

        try {
            // ── Step 1a: Parse suspicious if needed ──
            if (!suspiciousEmailId && suspiciousFile) {
                parseTimer.start("Parsing suspicious email…");
                const fd = new FormData();
                fd.append("file", suspiciousFile);
                const r = await fetch(`${API_URL}/parse-email`, {
                    method: "POST",
                    body: fd,
                });
                const d = await r.json();
                if (!r.ok)
                    throw new Error(
                        d.detail || "Failed to parse suspicious email.",
                    );
                suspiciousEmailId = d.email_id;
                parseTimer.done("Suspicious email parsed.");
                parseTimer.start("Parsing legitimate email…");
            } else {
                parseTimer.start("Parsing legitimate email…");
            }

            // ── Step 1b: Parse legitimate ──
            const fdLegit = new FormData();
            fdLegit.append("file", legitimateFile);
            const legRes = await fetch(`${API_URL}/parse-email`, {
                method: "POST",
                body: fdLegit,
            });
            const legData = await legRes.json();
            if (!legRes.ok)
                throw new Error(
                    legData.detail || "Failed to parse legitimate email.",
                );
            const legitimateEmailId = legData.email_id;
            parseTimer.done(`Parsed → ${legitimateEmailId.slice(0, 8)}…`);

            // ── Step 2: Diff check ──
            compareTimer.start("Running comparison…");
            const diffRes = await fetch(`${API_URL}/diff-check`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    suspicious_email_id: suspiciousEmailId,
                    legitimate_email_id: legitimateEmailId,
                }),
            });
            const diffData = await diffRes.json();
            if (!diffRes.ok)
                throw new Error(
                    diffData.detail || "Diff check failed.",
                );
            compareTimer.done("Comparison complete.");

            displayDiffResults(diffData);
        } catch (err: any) {
            const msg = err.message || "Something went wrong.";
            showError(msg);
            // Mark whichever step is running as errored
            if (wfParse.dataset.status === "running") parseTimer.error(msg);
            if (wfCompare.dataset.status === "running") compareTimer.error(msg);
        } finally {
            compareBtn.disabled = false;
            updateCompareBtn();
        }
    });

    // ───────────────────────────────────
    //  Display diff results
    // ───────────────────────────────────
    function displayDiffResults(data: any) {
        const risk = data.risk_assessment || {};
        const level = risk.risk_level || "low";
        const banner = document.getElementById("risk-banner")!;

        // Reset classes
        banner.className =
            "flex items-center gap-3 rounded-md border px-4 py-3";
        banner.classList.add(`risk-${level}`);
        document.getElementById("risk-level")!.textContent =
            level.toUpperCase();
        document.getElementById("risk-score-badge")!.textContent =
            `Score: ${risk.risk_score ?? "—"}`;
        document.getElementById("risk-verdict")!.textContent =
            risk.verdict || "";

        // Anomalies
        const anomalies: string[] = risk.all_anomalies || [];
        const anomSection = document.getElementById("anomalies-section")!;
        const anomDetails = document.getElementById(
            "anomalies-details",
        ) as HTMLDetailsElement;
        const anomSummaryText = document.getElementById(
            "anomalies-summary-text",
        )!;
        const anomList = document.getElementById("anomalies-list")!;
        anomList.innerHTML = "";
        anomSection.hidden = false;
        anomSummaryText.textContent =
            `View all anomalies (${anomalies.length})`;
        anomDetails.open = false;
        if (anomalies.length > 0) {
            anomalies.forEach((a) => {
                const li = document.createElement("li");
                li.className =
                    "flex items-start gap-2 rounded-md border border-red-100 bg-red-50/60 px-3 py-2 text-[12px] text-red-800";
                li.innerHTML = `<span class="shrink-0 mt-px">⚠</span><span>${escHtml(a)}</span>`;
                anomList.appendChild(li);
            });
        } else {
            const li = document.createElement("li");
            li.className =
                "rounded-md border border-neutral-200 bg-neutral-50 px-3 py-2 text-[12px] text-neutral-500";
            li.textContent = "No anomalies found.";
            anomList.appendChild(li);
        }

        // Header comparison table
        const headerWrap = document.getElementById("header-table-wrap")!;
        headerWrap.innerHTML = buildHeaderTable(data.header_comparison || {});

        // Auth scores
        const auth = data.auth_comparison || {};
        document.getElementById("auth-susp-score")!.textContent =
            auth.suspicious_total_score?.toFixed(1) ?? "—";
        document.getElementById("auth-susp-action")!.textContent =
            auth.suspicious_action || "";
        document.getElementById("auth-legit-score")!.textContent =
            auth.legitimate_total_score?.toFixed(1) ?? "—";
        document.getElementById("auth-legit-action")!.textContent =
            auth.legitimate_action || "";
        const delta = auth.score_delta;
        const deltaEl = document.getElementById("auth-delta")!;
        const deltaBox = document.getElementById("deltaBox")!;
        deltaBox.classList.remove(
            "bg-red-50",
            "border-red-200",
            "bg-green-50",
            "border-green-200",
        );
        if (delta !== null && delta !== undefined) {
            if (delta > 3) {
                deltaBox.classList.add("bg-red-50", "border-red-200");
            } else if (delta < -1) {
                deltaBox.classList.add("bg-green-50", "border-green-200");
            }
            deltaEl.textContent =
                (delta > 0 ? "+" : "") + delta.toFixed(1);
            deltaEl.className =
                "text-[18px] font-semibold tabular-nums " +
                (delta > 3 ? "text-red-600" : delta < -1 ? "text-green-600" : "text-neutral-900");
        } else {
            deltaEl.textContent = "—";
            deltaEl.className =
                "text-[18px] font-semibold tabular-nums text-neutral-500";
        }

        // Auth symbols table
        const authSymbolsDetails = document.getElementById(
            "auth-symbols-details",
        ) as HTMLDetailsElement;
        const authSymbolsSummaryText = document.getElementById(
            "auth-symbols-summary-text",
        )!;
        const authWrap = document.getElementById("auth-symbols-wrap")!;
        const authSymbols = auth.symbols || {};
        authSymbolsSummaryText.textContent =
            `View all symbols (${Object.keys(authSymbols).length})`;
        authSymbolsDetails.open = false;
        authWrap.innerHTML = buildAuthTable(authSymbols);

        // IP / Geo
        const ip = data.ip_geo_comparison || {};
        document.getElementById("ip-shared-count")!.textContent = String(
            ip.shared_ips?.length ?? 0,
        );
        document.getElementById("ip-susp-only-count")!.textContent = String(
            ip.suspicious_only_ips?.length ?? 0,
        );
        document.getElementById("ip-legit-only-count")!.textContent = String(
            ip.legitimate_only_ips?.length ?? 0,
        );

        document.getElementById("ip-susp-countries")!.innerHTML =
            `<span class="text-neutral-500">Suspicious:</span> ${(ip.suspicious_countries || []).join(", ") || "—"}`;
        document.getElementById("ip-legit-countries")!.innerHTML =
            `<span class="text-neutral-500">Legitimate:</span> ${(ip.legitimate_countries || []).join(", ") || "—"}`;

        const ipGeoWrap = document.getElementById("ip-geo-table-wrap")!;
        ipGeoWrap.innerHTML = buildGeoTable(ip.geo_details || []);

        // Body similarity
        const body = data.body_similarity || {};
        const ratio = body.similarity_ratio;
        document.getElementById("body-ratio")!.textContent =
            ratio !== null && ratio !== undefined
                ? `${(ratio * 100).toFixed(1)}%`
                : "—";
        const interp = body.interpretation || "";
        const interpEl = document.getElementById("body-interp")!;
        interpEl.textContent = interp;
        interpEl.className = "text-[11px] px-1.5 py-px rounded-full ";
        if (interp === "very_high" || interp === "high") {
            interpEl.classList.add("bg-amber-100", "text-amber-700");
        } else if (interp === "moderate") {
            interpEl.classList.add("bg-yellow-100", "text-yellow-700");
        } else {
            interpEl.classList.add("bg-neutral-100", "text-neutral-500");
        }
        document.getElementById("body-note")!.textContent = body.note || "";

        resultsEl.hidden = false;
    }

    // ───────────────────────────────────
    //  Table builders
    // ───────────────────────────────────
    function escHtml(s: string) {
        const d = document.createElement("div");
        d.textContent = s;
        return d.innerHTML;
    }

    const ROW_CLS =
        "grid min-h-9 grid-cols-[90px_1fr_1fr_60px] items-center";
    const CELL_CLS = "px-3 py-2 text-[12px] break-all";
    const HEAD_CLS = `${CELL_CLS} bg-neutral-50 text-neutral-500 font-medium`;

    function buildHeaderTable(headers: Record<string, any>): string {
        let rows = `
            <div class="${ROW_CLS} border-b border-neutral-200">
                <div class="${HEAD_CLS}">Header</div>
                <div class="${HEAD_CLS}">Suspicious</div>
                <div class="${HEAD_CLS}">Legitimate</div>
                <div class="${HEAD_CLS}">Match</div>
            </div>`;
        for (const [key, val] of Object.entries(headers)) {
            if (key.startsWith("_")) continue;
            if (!val || typeof val !== "object") continue;
            const match = val.domain_match;
            const matchBg = match
                ? "bg-green-50 text-green-700"
                : "bg-red-50 text-red-700";
            rows += `
                <div class="${ROW_CLS} border-t border-neutral-200">
                    <div class="${CELL_CLS} text-neutral-500 font-medium bg-neutral-50 border-r border-neutral-200">${escHtml(key)}</div>
                    <div class="${CELL_CLS} text-neutral-900">${escHtml(val.suspicious || "—")}</div>
                    <div class="${CELL_CLS} text-neutral-900">${escHtml(val.legitimate || "—")}</div>
                    <div class="${CELL_CLS} text-[13px] text-center tracking-widest font-semibold ${matchBg}">${match ? "YES" : "NO"}</div>
                </div>`;
        }
        return rows;
    }

    function buildAuthTable(symbols: Record<string, any>): string {
        const keys = Object.keys(symbols);
        if (keys.length === 0)
            return '<div class="px-3 py-2 text-[12px] text-neutral-500">No auth symbols to compare.</div>';

        let rows = `
            <div class="grid min-h-9 grid-cols-[1fr_60px_60px] items-center border-b border-neutral-200">
                <div class="${HEAD_CLS}">Symbol</div>
                <div class="${HEAD_CLS} text-center">Susp</div>
                <div class="${HEAD_CLS} text-center">Legit</div>
            </div>`;
        for (const [sym, val] of Object.entries(symbols)) {
            const inS = val.in_suspicious;
            const inL = val.in_legitimate;
            rows += `
                <div class="grid min-h-9 grid-cols-[1fr_60px_60px] items-center border-t border-neutral-200">
                    <div class="${CELL_CLS} text-neutral-900">${escHtml(sym)}</div>
                    <div class="${CELL_CLS} text-center ${inS ? "text-neutral-900" : "text-neutral-300"}">${inS ? "●" : "—"}</div>
                    <div class="${CELL_CLS} text-center ${inL ? "text-neutral-900" : "text-neutral-300"}">${inL ? "●" : "—"}</div>
                </div>`;
        }
        return rows;
    }

    function buildGeoTable(details: any[]): string {
        if (!details.length)
            return '<div class="px-3 py-2 text-[12px] text-neutral-500">All IPs shared between both emails.</div>';

        let rows = `
            <div class="grid min-h-9 grid-cols-[2fr_1fr_1fr_2fr_1fr] items-center border-b border-neutral-200">
                <div class="${HEAD_CLS}">IP</div>
                <div class="${HEAD_CLS}">Source</div>
                <div class="${HEAD_CLS}">Country</div>
                <div class="${HEAD_CLS}">ISP</div>
                <div class="${HEAD_CLS}">Flags</div>
            </div>`;
        for (const d of details) {
            const flags: string[] = [];
            if (d.proxy) flags.push("Proxy");
            if (d.hosting) flags.push("Hosting");
            const srcCls =
                d.source === "suspicious_only"
                    ? "text-amber-700 bg-amber-50"
                    : "text-blue-700 bg-blue-50";
            const srcLabel =
                d.source === "suspicious_only" ? "Suspicious" : "Legitimate";
            rows += `
                <div class="grid min-h-9 grid-cols-[2fr_1fr_1fr_2fr_1fr] items-center border-t border-neutral-200">
                    <div class="${CELL_CLS} text-neutral-900">${escHtml(d.ip || "—")}</div>
                    <div class="${CELL_CLS}"><span class="text-[10px] px-1 py-px rounded ${srcCls}">${srcLabel}</span></div>
                    <div class="px-3 py-2 text-[12px] text-neutral-700 break-words">${escHtml(d.country || "—")}</div>
                    <div class="${CELL_CLS} text-neutral-700">${escHtml(d.isp || "—")}</div>
                    <div class="px-3 py-2 text-neutral-500 text-[11px] break-words">${flags.length ? flags.join(", ") : "—"}</div>
                </div>`;
        }
        return rows;
    }
</script>
