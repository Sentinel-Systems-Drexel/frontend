---
import { url } from "../scripts/url";
---

<header
    class="sticky top-0 z-50 border-b border-neutral-200 bg-neutral-50 antialiased px-6 md:px-20 lg:px-40"
>
    <div class="flex h-13 justify-between max-w-270 mx-auto">
        <a
            href={url("/")}
            class="flex items-center align-baseline gap-2.5 text-[15px] font-semibold text-neutral-900 no-underline"
        >
            <img
                class="h-6 w-6 m-auto"
                src={url("/sentinel_systems_logo.png")}
                alt="Sentinel Systems Logo"
            />
            <span class="my-auto">Sentinel Systems</span>
        </a>

        <nav class="flex items-center gap-4">
            <a
                href={url("/")}
                class="rounded-md px-2.5 py-1.5 text-[13px] text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
            >
                Analyzer
            </a>
            <a
                href={url("/diff/")}
                class="rounded-md px-2.5 py-1.5 text-[13px] text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
            >
                Diff-Checker
            </a>
            <a
                href={url("/docs/")}
                class="rounded-md px-2.5 py-1.5 text-[13px] text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
            >
                Docs
            </a>
            <a
                href={url("/github/")}
                class="rounded-md px-2.5 py-1.5 text-[13px] text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
            >
                GitHub
            </a>
        </nav>
    </div>
</header>
