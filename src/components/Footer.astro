---
import { url } from "../scripts/url";
---

<footer class="mt-auto border-t border-neutral-200">
    <div
        class="mx-auto flex max-w-190 items-center justify-between px-6 py-5"
    >
        <span class="text-[12px] text-neutral-400">
            © {new Date().getFullYear()} Sentinel Systems
        </span>
        <div class="flex gap-4">
            <a
                href={url("/privacy/")}
                class="text-[12px] text-neutral-400 no-underline transition-colors hover:text-neutral-500"
            >
                Privacy
            </a>
            <a
                href={url("/terms/")}
                class="text-[12px] text-neutral-400 no-underline transition-colors hover:text-neutral-500"
            >
                Terms
            </a>
        </div>
    </div>
</footer>
