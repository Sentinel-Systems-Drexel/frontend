---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title?: string;
	description?: string;
}

const { title = "Sentinel Systems", description } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/png" href={base + "sentinel_systems_logo.png"}>

		<title>{title}</title>
		<meta name="description" content={description}>

		<meta property="og:type" content="website">
		<meta property="og:title" content={title}>
		<meta property="og:description" content={description}>
		<meta property="og:image" content={base + "cover.png"}>
		<meta property="twitter:card" content={base + "cover.png"}>
		<meta property="twitter:title" content={title}>
	</head>
	<body class="m-0 p-0">
        <Header />
		<slot />
        <Footer />
	</body>
</html>
